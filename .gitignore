dynasty_bball.db-journal
test_dynasty_bball.db

# Data drops (large files are pulled live, not committed)
data/**/*.csv
data/**/*.json
data/**/*.parquet
!data/**/.gitkeep
!tests/fixtures/**
# Basketball-Reference cache is small (~200KB/season) and we ship it
# in the repo so the daily CI build is deterministic and doesn't
# hammer stats.nba.com. See sources/basketball_reference.py.
!data/basketball_reference/*.json
!data/historical_nba/*.json
!data/career_arc/*.json
# Name resolver: ship the curated alias map (small, hand-edited) and
# the diagnostic sidecars so the rendered site banner has data on a
# fresh clone before the first sync.
!data/name_aliases.json
!data/diagnostics/*.json

# OS
Thumbs.db
